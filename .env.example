# Qwen Cloud (DashScope)
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Alibaba Cloud OSS
ALIBABA_ACCESS_KEY_ID=your_access_key_id_here
ALIBABA_ACCESS_KEY_SECRET=your_access_key_secret_here
OSS_ENDPOINT=https://oss-ap-southeast-1.aliyuncs.com
OSS_BUCKET_NAME=revoice-media

# Alibaba Cloud Function Compute
FC_REGION=ap-southeast-1

# App settings
DATABASE_URL=sqlite:///./revoice.db
USE_MOCK_QWEN=true
DEBUG=false
